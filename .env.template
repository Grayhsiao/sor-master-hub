# .env.template — 所有專案共用的環境變數範本
# 使用方式：
#   1. 複製此檔案為 .env（位於對應專案資料夾內）
#   2. 填入你的真實 API Key
#   3. 執行腳本前：source .env  或讓 python-dotenv 自動載入
#
# ⚠️ 絕對不要把含有真實 Key 的 .env 上傳到 git！

# ── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=sk-proj-你的OpenAI金鑰貼在這裡

# ── Google Gemini / Generative AI ─────────────────
GOOGLE_API_KEY=AIzaSy你的Gemini金鑰貼在這裡

# ── LINE Bot ──────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=你的LINE存取金鑰
LINE_CHANNEL_SECRET=你的LINE頻道密鑰

# ── Google Sheets（bookeep 用）────────────────────
GOOGLE_SHEETS_ID=你的試算表ID
FAMILY_USER_IDS=LINE_USER_ID_1,LINE_USER_ID_2

# ── 其他 ──────────────────────────────────────────
# D-ID API（700單影片製作用，選填）
DID_API_KEY=你的DID金鑰
